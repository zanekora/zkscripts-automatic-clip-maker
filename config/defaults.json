{
  "paths": {
    "input": "input",
    "output": "output",
    "review": "review",
    "logs": "logs"
  },
  "ffmpeg": {
    "ffmpeg_path": "ffmpeg",
    "ffprobe_path": "ffprobe"
  },
  "export": {
    "export_fight_clips": false,
    "export_combined_video": false,
    "fight_subdir_name": "fights",
    "combined_filename": "combined_highlights.mp4",
    "video_codec": "libx264",
    "audio_codec": "aac",
    "crf": 18,
    "preset": "medium",
    "transition_mode": "fade",
    "transition_duration_seconds": 0.35
  },
  "analysis": {
    "supported_extensions": [
      ".mp4",
      ".mkv",
      ".mov",
      ".avi",
      ".m4v",
      ".webm"
    ],
    "segmentation_mode": "hybrid",
    "overlap_warning_min_seconds": 0.5,
    "minimum_keep_segment_seconds": 30.0,
    "merge_gap_seconds": 3.0,
    "reuse_analysis_by_default": true,
    "blackdetect": {
      "enabled": true,
      "min_duration": 0.75,
      "pixel_threshold": 0.1,
      "picture_threshold": 0.98
    },
    "scene_detection": {
      "enabled": true,
      "threshold": 27.0,
      "min_scene_length_seconds": 2.0
    },
    "active_fight_detection": {
      "enabled": true,
      "templates_dir": "presets/infight_templates",
      "protection_weight": 1.25,
      "sample_interval_seconds": 0.2,
      "similarity_threshold": 0.78,
      "min_match_duration_seconds": 1.0,
      "leading_keep_seconds": 0.5,
      "trailing_keep_seconds": 1.5,
      "min_consecutive_hits": 2,
      "release_after_misses": 3,
      "require_dynamic_frame": true,
      "max_static_changed_pixel_ratio": 0.10
    },
    "visual_cut_detection": {
      "enabled": true,
      "fullscreen_templates_dir": "presets/fullscreen_templates",
      "partial_templates_dir": "presets/partial_templates",
      "terminal_templates_dir": "presets/terminal_templates",
      "cut_weight": 1.0,
      "terminal_cut_weight": 1.15,
      "sample_interval_seconds": 0.2,
      "template_similarity_threshold": 0.72,
      "min_template_match_duration_seconds": 2.0,
      "template_only_cut_requires_static": true,
      "unscoped_template_enabled": false,
      "small_template_late_match_enabled": true,
      "small_template_max_coverage": 0.12,
      "small_template_extra_similarity": 0.05,
      "sticky_region_match_enabled": true,
      "sticky_region_min_consecutive_hits": 2,
      "sticky_region_release_seconds": 1.5,
      "flash_transition_enabled": true,
      "flash_brightness_delta_threshold": 55.0,
      "flash_changed_pixel_ratio_threshold": 0.65,
      "flash_bright_pixel_ratio_threshold": 0.45,
      "flash_follow_window_seconds": 4.0,
      "flash_terminal_tail_enabled": true,
      "terminal_region_detector_enabled": true,
      "terminal_region_start_fraction": 0.85,
      "terminal_region_min_template_hits": 3,
      "terminal_template_min_unique_matches": 2,
      "terminal_large_template_min_coverage": 0.08,
      "terminal_region_edge_density_threshold": 0.05,
      "terminal_region_text_like_threshold": 0.012,
      "terminal_region_min_duration_seconds": 1.0,
      "static_screen_enabled": true,
      "static_motion_threshold": 4.5,
      "static_edge_density_threshold": 0.06,
      "static_text_like_threshold": 0.015,
      "min_static_duration_seconds": 1.5
    }
  }
}
