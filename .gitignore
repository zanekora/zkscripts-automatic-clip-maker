# Virtual environments
.venv/
venv/

# Local analysis inputs/outputs
# Runtime media, reports, logs, and generated exports should not be committed.
input/*
!input/.gitkeep
input_*/*
intermediate/*
!intermediate/.gitkeep
output/*
!output/.gitkeep
output_*/*
review/*
!review/.gitkeep
review_*/*
logs/*
!logs/.gitkeep
logs_*/*
.temp/
review_candidate/

